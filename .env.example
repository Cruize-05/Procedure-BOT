# ──────────────────────────────────────────────────────────────────────────────
# ProcedureBot CM — Local Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# On Vercel: set these in Project → Settings → Environment Variables.
# On GitLab CI: set them as masked CI/CD variables.
# ──────────────────────────────────────────────────────────────────────────────

# ── AI / Gemini ───────────────────────────────────────────────────────────────
# Google Gemini API key used by the Edge Function (chat-stream.js).
# Server-side only — must NEVER be exposed to the client bundle.
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string.
# Server-side only (chat-stream.js, export-checklist.js, seed.js).
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/procedurebot?retryWrites=true&w=majority

# ── Runtime ───────────────────────────────────────────────────────────────────
# Affects build tooling and conditional log verbosity.
# Accepted values: development | production | test
NODE_ENV=development

# ── Vercel (local emulation) ──────────────────────────────────────────────────
# Optional: Vercel project/team IDs for `vercel dev` / `vercel build` locally.
# VERCEL_ORG_ID=your_org_id
# VERCEL_PROJECT_ID=your_project_id
